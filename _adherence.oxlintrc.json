{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/general/AgeWarning/**",
              "components/general/ArticleCard/**",
              "components/general/Breadcrumb/**",
              "components/general/CodeBlock/**",
              "components/general/DataChart/**",
              "components/general/Hero/**",
              "components/general/KeyPointsBox/**",
              "components/general/LeadForm/**",
              "components/general/LiveBlog/**",
              "components/general/Navigation/**",
              "components/general/PaywallPrompt/**",
              "components/general/TickerBar/**",
              "uploads/**",
              "villes/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cambria|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Cambria, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgeWarning'] > JSXAttribute > JSXIdentifier[name!=/^(?:publishedAt|thresholdMonths|className|key|ref|className|style|children)$/]",
        "message": "<AgeWarning> doesn't accept that prop. Declared props: publishedAt, thresholdMonths, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|href|variant|deck|category|pillar|author|timestamp|imageSrc|imageAlt|isBreaking|readingTimeMin|className|key|ref|className|style|children)$/]",
        "message": "<ArticleCard> doesn't accept that prop. Declared props: headline, href, variant, deck, category, pillar, author, timestamp, imageSrc, imageAlt, isBreaking, readingTimeMin, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lead|standard|brief)$/]",
        "message": "<ArticleCard> variant must be one of 'lead' | 'standard' | 'brief'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute[name.name='pillar'] > Literal[value!=/^(?:news|opinion|sport|culture|lifestyle|world)$/]",
        "message": "<ArticleCard> pillar must be one of 'news' | 'opinion' | 'sport' | 'culture' | 'lifestyle' | 'world'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|className|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: items, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|language|filename|showLineNumbers|className|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: code, language, filename, showLineNumbers, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|type|title|unit|source|color|className|key|ref|className|style|children)$/]",
        "message": "<DataChart> doesn't accept that prop. Declared props: data, type, title, unit, source, color, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataChart'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:line|bar|sparkline)$/]",
        "message": "<DataChart> type must be one of 'line' | 'bar' | 'sparkline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|variant|deck|imageSrc|imageAlt|primaryCTA|secondaryCTA|category|trustBadge|className|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: headline, variant, deck, imageSrc, imageAlt, primaryCTA, secondaryCTA, category, trustBadge, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:editorial|product|text-only)$/]",
        "message": "<Hero> variant must be one of 'editorial' | 'product' | 'text-only'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyPointsBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:points|title|className|key|ref|className|style|children)$/]",
        "message": "<KeyPointsBox> doesn't accept that prop. Declared props: points, title, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeadForm'] > JSXAttribute > JSXIdentifier[name!=/^(?:fields|submitLabel|onSubmit|successMessage|errorMessage|className|key|ref|className|style|children)$/]",
        "message": "<LeadForm> doesn't accept that prop. Declared props: fields, submitLabel, onSubmit, successMessage, errorMessage, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveBlog'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|isLive|entries|showKeyEventsOnly|className|key|ref|className|style|children)$/]",
        "message": "<LiveBlog> doesn't accept that prop. Declared props: headline, isLive, entries, showKeyEventsOnly, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navigation'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|logoHref|items|ctaLabel|ctaHref|variant|className|key|ref|className|style|children)$/]",
        "message": "<Navigation> doesn't accept that prop. Declared props: logo, logoHref, items, ctaLabel, ctaHref, variant, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navigation'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:editorial|product)$/]",
        "message": "<Navigation> variant must be one of 'editorial' | 'product'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaywallPrompt'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|headline|body|ctaLabel|ctaHref|articlesRemaining|className|key|ref|className|style|children)$/]",
        "message": "<PaywallPrompt> doesn't accept that prop. Declared props: variant, headline, body, ctaLabel, ctaHref, articlesRemaining, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaywallPrompt'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|hard|support)$/]",
        "message": "<PaywallPrompt> variant must be one of 'soft' | 'hard' | 'support'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|label|className|key|ref|className|style|children)$/]",
        "message": "<TickerBar> doesn't accept that prop. Declared props: items, label, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
