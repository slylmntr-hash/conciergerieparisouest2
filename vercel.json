{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/$1" },
    { "source": "/images/villes/(.*)", "destination": "/$1" },
    { "source": "/images/(.*)", "destination": "/$1" },
    { "source": "/villes/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|woff2|woff)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

